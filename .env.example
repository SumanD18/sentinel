# Copy to .env and adjust. All values are optional; defaults give a working
# local SQLite-backed stack with auth disabled.

# --- Server ---------------------------------------------------------------
# SQLite (default) or Postgres, e.g.
#   postgresql+asyncpg://sentinel:sentinel@db:5432/sentinel
SENTINEL_DATABASE_URL=sqlite+aiosqlite:////data/sentinel.db

# Comma-separated API keys. Leave empty to disable auth (local dev).
SENTINEL_API_KEYS=

# CORS origins for the dashboard ("*" for any).
SENTINEL_CORS_ORIGINS=*

SENTINEL_LOG_LEVEL=INFO
SENTINEL_ALERT_TRUST_THRESHOLD=0.5
SENTINEL_RUNAWAY_SPAN_THRESHOLD=50

# Delete traces older than this many days (0 = keep forever). A background
# sweep runs hourly when this is > 0.
SENTINEL_RETENTION_DAYS=0

# --- SDK (apps that send traces) ------------------------------------------
SENTINEL_ENDPOINT=http://localhost:8000
SENTINEL_SERVICE_NAME=my-service
SENTINEL_ENVIRONMENT=development
# SENTINEL_API_KEY=   # must match one of SENTINEL_API_KEYS if auth is on
